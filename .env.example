# ============================================
# 数据库配置
# ============================================
# 本地开发（SQLite）:
DATABASE_URL="file:./dev.db"
# 生产部署（Railway PostgreSQL）:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ============================================
# Google OAuth 2.0 凭证
# 从 https://console.cloud.google.com/apis/credentials 获取
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# Google Places API 密钥
# 从 https://console.cloud.google.com/apis/credentials 创建 API Key
# 用于搜索和验证 Google Business 商家位置
# ============================================
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# ============================================
# AI API 密钥
# ============================================
GEMINI_API_KEY="your-gemini-api-key"
SERPAPI_KEY="your-serpapi-key"

# ============================================
# 应用配置
# ============================================
# 重要！部署到 Railway 时必须修改为你的 Railway 域名
# 本地开发:
APP_URL="http://localhost:3000"
# 生产部署（Railway）:
# APP_URL="https://xxxx.railway.app"
